# ---------------------------------------------------------------------------
# OpenAI Configuration
# ---------------------------------------------------------------------------

# Required for the GPT-5.6 Watcher and Reviewer calls.
OPENAI_API_KEY=

# Cost-conscious GPT-5.6 family default; may be overridden at runtime.
OPENAI_MODEL=gpt-5.6-luna

# OpenAI API timeout in seconds
OPENAI_TIMEOUT=120

# ---------------------------------------------------------------------------
# Codex Configuration
# ---------------------------------------------------------------------------

# Codex timeout in seconds
CODEX_TIMEOUT=120

# Maximum output bytes from Codex CLI
CODEX_MAX_OUTPUT_BYTES=524288

# ---------------------------------------------------------------------------
# Repository & Paths
# ---------------------------------------------------------------------------

# Target repository path (relative or absolute)
TARGET_REPO_PATH=seeded_repo

# Artifacts output directory
ARTIFACTS_DIR=artifacts

# Logs directory
LOGS_DIR=logs

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLite database URL
DATABASE_URL=sqlite:///logs/run_log.db

# ---------------------------------------------------------------------------
# API Server Configuration
# ---------------------------------------------------------------------------

# API server host
API_HOST=0.0.0.0

# API server port
API_PORT=8000

# Hot reload for development (set to true during development)
API_RELOAD=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---------------------------------------------------------------------------
# Rate Limiting & Safety
# ---------------------------------------------------------------------------

# Maximum issues per scan
MAX_ISSUES_PER_SCAN=50

# Maximum concurrent fixes
MAX_CONCURRENT_FIXES=3
